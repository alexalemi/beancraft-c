# Nth Fibonacci number -> Out.  fib(0) = 0, fib(1) = 1.
# Iterate (a, b) := (b, a + b), N times, then Out := a.
# tmp is scratch; a, b are consumed.

c1: - a c2 self
c2: - b c3 self
c3: - tmp setup self

# a := 0 (already cleared), b := 1
setup: + b loop

loop: - N result

# tmp := b   (b is left at 0)
mvB: - b mvA
+ tmp mvB

# b := a   (a is left at 0; b was 0)
mvA: - a mvT
+ b mvA

# a := tmp ; b += tmp   (tmp is left at 0)
mvT: - tmp loop
+ a
+ b mvT

# Out := a
result: - a done
+ Out prev
