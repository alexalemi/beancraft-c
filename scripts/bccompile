#!/bin/bash
# Compile a Beancraft program to a native executable using QBE
#
# Usage: bccompile input.bc [output]
#
# Requires: beancraft, qbe, cc

set -e

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
BEANCRAFT="${BEANCRAFT:-$PROJECT_DIR/beancraft}"
RUNTIME_C="$PROJECT_DIR/src/qbe_runtime.c"
DRIVER_C="$PROJECT_DIR/src/qbe_driver.c"

if [ $# -lt 1 ]; then
    echo "Usage: $0 input.bc [output]"
    echo ""
    echo "Compiles a Beancraft program to a native executable."
    echo ""
    echo "Options:"
    echo "  -O        Enable loop optimizations (TRANSFER, ZERO patterns)"
    echo "  -O0       Disable optimizations"
    echo "  -g        Enable debug info"
    echo "  --gmp     Enable GMP bignum support (requires libgmp)"
    echo "  -v        Verbose output"
    exit 1
fi

INPUT=""
OUTPUT=""
CFLAGS="-O2"
GMP_FLAGS=""
VERBOSE=""
BC_OPT=""

while [ $# -gt 0 ]; do
    case "$1" in
        -O)
            CFLAGS="-O2"
            BC_OPT="-O"
            ;;
        -O0)
            CFLAGS="-O0"
            BC_OPT=""
            ;;
        -g)
            CFLAGS="$CFLAGS -g"
            ;;
        --gmp)
            GMP_FLAGS="-DUSE_GMP -lgmp"
            ;;
        -v)
            VERBOSE=1
            ;;
        *)
            if [ -z "$INPUT" ]; then
                INPUT="$1"
            elif [ -z "$OUTPUT" ]; then
                OUTPUT="$1"
            else
                echo "Error: unexpected argument '$1'"
                exit 1
            fi
            ;;
    esac
    shift
done

if [ -z "$INPUT" ]; then
    echo "Error: no input file specified"
    exit 1
fi

if [ -z "$OUTPUT" ]; then
    # Default output name: strip .bc extension
    OUTPUT="${INPUT%.bc}"
    if [ "$OUTPUT" = "$INPUT" ]; then
        OUTPUT="${INPUT}.out"
    fi
fi

# Create temp directory
TMPDIR=$(mktemp -d)
trap "rm -rf $TMPDIR" EXIT

[ -n "$VERBOSE" ] && echo "Generating QBE IL..."
"$BEANCRAFT" "$INPUT" --emit-qbe $BC_OPT > "$TMPDIR/prog.ssa"

[ -n "$VERBOSE" ] && echo "Compiling QBE IL to assembly..."
qbe -o "$TMPDIR/prog.s" "$TMPDIR/prog.ssa"

[ -n "$VERBOSE" ] && echo "Assembling and linking..."
cc $CFLAGS -c -o "$TMPDIR/prog.o" "$TMPDIR/prog.s"
cc $CFLAGS $GMP_FLAGS -c -o "$TMPDIR/runtime.o" "$RUNTIME_C"
cc $CFLAGS -c -o "$TMPDIR/driver.o" "$DRIVER_C"
cc $CFLAGS $GMP_FLAGS -o "$OUTPUT" "$TMPDIR/prog.o" "$TMPDIR/runtime.o" "$TMPDIR/driver.o"

[ -n "$VERBOSE" ] && echo "Done: $OUTPUT"
