#!/bin/bash
# Compile a Beancraft program to a native executable using QBE.
#
# Usage: bccompile [options] input.bc [output]
#
# Requires: beancraft, qbe, cc

set -e

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
BEANCRAFT="${BEANCRAFT:-$PROJECT_DIR/beancraft}"
INCLUDE_DIR="$PROJECT_DIR/include"
RUNTIME_C="$PROJECT_DIR/src/qbe_runtime.c"
BIGNUM_C="$PROJECT_DIR/src/bignum.c"
DEVICES_C="$PROJECT_DIR/src/devices.c"
DRIVER_C="$PROJECT_DIR/src/qbe_driver.c"

usage() {
    echo "Usage: $0 [options] input.bc [output]"
    echo ""
    echo "Compiles a Beancraft program to a native executable."
    echo ""
    echo "Options:"
    echo "  -O        Enable loop optimizations (TRANSFER, ZERO patterns)"
    echo "  -O0       Disable optimizations"
    echo "  -g        Include debug info in the binary"
    echo "  --sdl     Build the Screen device against SDL (window + mouse + key events)"
    echo "  -v        Verbose output"
}

if [ $# -lt 1 ]; then
    usage
    exit 1
fi

INPUT=""
OUTPUT=""
CFLAGS="-O2"
VERBOSE=""
BC_OPT=""
SDL_CFLAGS=""
SDL_LIBS=""

while [ $# -gt 0 ]; do
    case "$1" in
        -O)  CFLAGS="-O2"; BC_OPT="-O" ;;
        -O0) CFLAGS="-O0"; BC_OPT="" ;;
        -g)  CFLAGS="$CFLAGS -g" ;;
        --sdl) SDL_CFLAGS="-DBC_SDL $(pkg-config --cflags sdl2 2>/dev/null)"
               SDL_LIBS="$(pkg-config --libs sdl2 2>/dev/null || echo -lSDL2)" ;;
        -v)  VERBOSE=1 ;;
        -h|--help) usage; exit 0 ;;
        *)
            if [ -z "$INPUT" ]; then
                INPUT="$1"
            elif [ -z "$OUTPUT" ]; then
                OUTPUT="$1"
            else
                echo "Error: unexpected argument '$1'"
                exit 1
            fi
            ;;
    esac
    shift
done

if [ -z "$INPUT" ]; then
    echo "Error: no input file specified"
    exit 1
fi

if [ -z "$OUTPUT" ]; then
    OUTPUT="${INPUT%.bc}"
    [ "$OUTPUT" = "$INPUT" ] && OUTPUT="${INPUT}.out"
fi

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

[ -n "$VERBOSE" ] && echo "Generating QBE IL..."
"$BEANCRAFT" "$INPUT" --emit-qbe $BC_OPT > "$TMPDIR/prog.ssa"

[ -n "$VERBOSE" ] && echo "Compiling QBE IL to assembly..."
qbe -o "$TMPDIR/prog.s" "$TMPDIR/prog.ssa"

[ -n "$VERBOSE" ] && echo "Assembling and linking..."
cc $CFLAGS -c -o "$TMPDIR/prog.o" "$TMPDIR/prog.s"
cc $CFLAGS -I "$INCLUDE_DIR" -c -o "$TMPDIR/runtime.o" "$RUNTIME_C"
cc $CFLAGS -I "$INCLUDE_DIR" -c -o "$TMPDIR/bignum.o" "$BIGNUM_C"
cc $CFLAGS $SDL_CFLAGS -I "$INCLUDE_DIR" -c -o "$TMPDIR/devices.o" "$DEVICES_C"
cc $CFLAGS -c -o "$TMPDIR/driver.o" "$DRIVER_C"
cc $CFLAGS -o "$OUTPUT" "$TMPDIR/prog.o" "$TMPDIR/runtime.o" "$TMPDIR/bignum.o" "$TMPDIR/devices.o" "$TMPDIR/driver.o" $SDL_LIBS

if [ -n "$VERBOSE" ]; then echo "Done: $OUTPUT"; fi
